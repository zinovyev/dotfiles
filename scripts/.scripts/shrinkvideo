#!/usr/bin/env bash

set -e

# --- Input validation ---
if [ -z "$1" ]; then
  echo "Error: No input file provided."
  echo "Usage: shrinkvideo <inputfile>"
  exit 1
fi

INPUT="$1"

if [ ! -f "$INPUT" ]; then
  echo "Error: File not found: $INPUT"
  exit 1
fi

# --- Prepare output name ---
BASENAME="${INPUT%.*}"
OUTPUT="${BASENAME}.compressed.mp4"

# ~100 MB target (800k video + 96k audio ≈ <100MB for typical lengths)
ffmpeg -i "$INPUT" -b:v 800k -b:a 96k -y "$OUTPUT"

echo "Done → $OUTPUT"
